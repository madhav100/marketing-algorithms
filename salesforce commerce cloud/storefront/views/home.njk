<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ storeName }}</title>
  <link rel="stylesheet" href="/storefront/css/site.css" />
</head>
<body>
  <h1>{{ welcomeMessage }}</h1>
  <h2>Featured Products</h2>
  <ul>
    {% for product in featuredProducts %}
      <li><a href="/product/{{ product.id }}">{{ product.name }}</a> - ${{ product.price }}</li>
    {% endfor %}
  </ul>

  <h3>Categories</h3>
  <ul>
    {% for category in categories %}
      <li>{{ category.name }}</li>
    {% endfor %}
  </ul>
</body>
</html>
